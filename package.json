{
  "name": "pokevendor",
  "version": "1.0.0",
  "description": "Card inventory and deal tracker",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/api\" \"npm run dev -w apps/web\"",
    "build": "npm run build -w apps/api && npm run build -w apps/web",
    "db:migrate": "npm run db:migrate -w apps/api",
    "db:push": "npm run db:push -w apps/api",
    "db:seed": "npm run db:seed -w apps/api",
    "hash:cards": "node --import tsx scripts/backfill-card-hashes.ts",
    "embed:cards": "node --import tsx scripts/backfill-card-embeddings.ts",
    "embed:index": "node --import tsx scripts/create-embedding-hnsw-index.ts",
    "embed:eval": "node --import tsx scripts/eval-embedding-retrieval.ts",
    "sync:tcgplayer-ids": "node --import tsx scripts/sync-tcgplayer-ids.ts",
    "db:backup": "./scripts/backup-db.sh",
    "db:restore": "./scripts/restore-db.sh"
  },
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prisma": "^5.20.0",
    "tsx": "^4.20.6"
  },
  "dependencies": {
    "sharp": "^0.34.2"
  }
}
